#!/usr/bin/env bash
# gstack-web-search — search the web via Exa API
# Usage: gstack-web-search "query" [--results N] [--contents] [--category X] [--domain X]
#        gstack-web-search --check   (exits 0 if configured, 1 if not)
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
GSTACK_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

if [ "${1:-}" = "--check" ]; then
  exec bun run "$GSTACK_DIR/scripts/exa-search.ts" check
fi

exec bun run "$GSTACK_DIR/scripts/exa-search.ts" search "$@"
