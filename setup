#!/usr/bin/env bash
# gstack setup — generate skill docs + register all skills with Claude Code
set -e

if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required but not installed." >&2
  echo "Install it: curl -fsSL https://bun.sh/install | bash" >&2
  exit 1
fi

GSTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$(dirname "$GSTACK_DIR")"
DOCS_RESEARCH_CAPABILITY="$GSTACK_DIR/capabilities/docs-research"

ensure_agent_browser() {
  if ! command -v agent-browser >/dev/null 2>&1; then
    echo "Error: agent-browser is required but not installed." >&2
    echo "Install it: npm install -g agent-browser && agent-browser install" >&2
    exit 1
  fi

  if ! agent-browser --version >/dev/null 2>&1; then
    echo "Error: agent-browser is installed but not runnable." >&2
    exit 1
  fi
}

ensure_docs_research_capability() {
  if [ ! -d "$DOCS_RESEARCH_CAPABILITY" ]; then
    return 0
  fi

  echo "Checking docs-research capability..."
  if ! "$DOCS_RESEARCH_CAPABILITY/check.sh"; then
    echo "Installing docs-research capability dependencies..."
    "$DOCS_RESEARCH_CAPABILITY/install.sh"
  fi
}

maybe_bootstrap_project() {
  [ "${GSTACK_SKIP_PROJECT_BOOTSTRAP:-0}" = "1" ] && return 0

  local skills_basename claude_dir project_root
  skills_basename="$(basename "$SKILLS_DIR")"
  [ "$skills_basename" != "skills" ] && return 0

  claude_dir="$(dirname "$SKILLS_DIR")"
  [ "$(basename "$claude_dir")" != ".claude" ] && return 0

  project_root="$(dirname "$claude_dir")"
  if ! git -C "$project_root" rev-parse --show-toplevel >/dev/null 2>&1; then
    return 0
  fi

  echo "Bootstrapping stack-aware project files..."
  (
    cd "$GSTACK_DIR"
    bun run scripts/stack-bootstrap.ts --project-root "$project_root"
  )
}

echo "Generating skill docs..."
(
  cd "$GSTACK_DIR"
  bun run gen:skill-docs
)

ensure_agent_browser
ensure_docs_research_capability

mkdir -p "$HOME/.gstack/projects"
maybe_bootstrap_project

SKILLS_BASENAME="$(basename "$SKILLS_DIR")"
if [ "$SKILLS_BASENAME" = "skills" ]; then
  linked=()
  for skill_dir in "$GSTACK_DIR"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      [ "$skill_name" = "node_modules" ] && continue
      target="$SKILLS_DIR/$skill_name"
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "gstack/$skill_name" "$target"
        linked+=("$skill_name")
      fi
    fi
  done

  echo "gstack ready."
  echo "  agent-browser: $(command -v agent-browser)"
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
else
  echo "gstack ready."
  echo "  agent-browser: $(command -v agent-browser)"
  echo "  (skipped skill symlinks — not inside .claude/skills/)"
fi

if [ ! -d "$HOME/.gstack" ]; then
  mkdir -p "$HOME/.gstack"
  echo "  Welcome! Run /gstack-upgrade anytime to stay current."
fi
rm -f /tmp/gstack-latest-version
